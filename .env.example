# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real tokens.

# --- Hugging Face / Pyannote ---
# Required for speaker diarization. Generate a "Read" token at
# https://huggingface.co/settings/tokens, and make sure you have accepted
# the license on BOTH of these model pages while logged in:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=

# --- WhisperX / Whisper ---
WHISPER_MODEL=large-v3
# Must be "cpu" on Mac because CTranslate2 does not support "mps" (Apple GPU) yet.
# "cuda" is supported if you move this to a Windows/Linux Nvidia machine.
DEVICE=cpu
# float32 is the safe default on cpu.
COMPUTE_TYPE=float32
BATCH_SIZE=8
# Leave blank to auto-detect language from the audio.
LANGUAGE=

# --- Diarization ---
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
# Leave blank to let pyannote auto-detect the number of speakers.
MIN_SPEAKERS=
MAX_SPEAKERS=

# --- Live Streaming ---
# Whisper model used for real-time (WebSocket) transcription.
# Smaller = faster (lower latency). Larger = more accurate but adds delay.
# Options: tiny | base | small | medium | large-v3
# Recommended: base (default) for live, large-v3 only on a fast GPU.
LIVE_WHISPER_MODEL=small
# Seconds of audio to buffer before each transcription pass.
# Lower = more responsive. Higher = more context = better accuracy.
LIVE_BUFFER_SECONDS=5.0
# Cosine distance threshold for Pyannote Wespeaker (0.0 - 1.0).
# Lower = stricter, higher = more lenient.
LIVE_WESPEAKER_THRESHOLD=0.65

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
# qwen3:8b replaced llama3.1:8b as the default (client feedback: better
# structured JSON extraction for summaries). Set back to llama3.1:8b to compare.
OLLAMA_MODEL=qwen3:8b
OLLAMA_REQUEST_TIMEOUT=300

# --- Pipeline engine selection (version2 benchmark toggles) ---
# All default to today's exact behavior. Flip one at a time to A/B compare —
# see backend/engines/ for what each alternative actually does.
# Upload VAD: none | fsmn
VAD_ENGINE=none
# Upload STT: whisperx | sensevoice
STT_ENGINE=whisperx
# Upload diarization: pyannote | campplusplus
DIARIZATION_ENGINE=pyannote
# Live VAD: silero | fsmn
LIVE_VAD_ENGINE=silero
# Punctuation restoration (FunASR CT-Transformer) before alignment. Off by
# default; only useful when STT output lacks punctuation.
ENABLE_PUNCTUATION_RESTORATION=false

# --- Summarization chunking ---
MAX_WORDS_PER_CHUNK=3000

# --- Logging ---
LOG_LEVEL=INFO
