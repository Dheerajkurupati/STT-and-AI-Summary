# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real tokens.

# --- Hugging Face / Pyannote ---
# Required for speaker diarization. Generate a "Read" token at
# https://huggingface.co/settings/tokens, and make sure you have accepted
# the license on BOTH of these model pages while logged in:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=

# --- WhisperX / Whisper ---
WHISPER_MODEL=large-v3
# "mps" for Apple Silicon (M1/M2/M3/M4), "cpu" for Intel Macs.
DEVICE=mps
# float32 is the safe default on cpu/mps. Only use float16 if you confirm
# your device/WhisperX version supports it without accuracy loss.
COMPUTE_TYPE=float32
BATCH_SIZE=8
# Leave blank to auto-detect language from the audio.
LANGUAGE=

# --- Diarization ---
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
# Leave blank to let pyannote auto-detect the number of speakers.
MIN_SPEAKERS=
MAX_SPEAKERS=

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_REQUEST_TIMEOUT=300

# --- Summarization chunking ---
MAX_WORDS_PER_CHUNK=3000

# --- Logging ---
LOG_LEVEL=INFO
